#!/usr/bin/env sh
set -eu

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "[pre-commit] gitleaks is not installed."
  echo "Install (macOS): brew install gitleaks"
  echo "Install (Linux): https://github.com/gitleaks/gitleaks#installing"
  exit 1
fi

CONFIG_FILE=".gitleaks.toml"
if [ ! -f "$CONFIG_FILE" ]; then
  echo "[pre-commit] Missing $CONFIG_FILE"
  exit 1
fi

# Prefer staged-only scan when available.
if gitleaks protect --help >/dev/null 2>&1; then
  gitleaks protect --staged --redact --config "$CONFIG_FILE" --verbose
else
  # Fallback for older/newer CLI variants.
  gitleaks detect --source . --redact --config "$CONFIG_FILE" --verbose
fi
