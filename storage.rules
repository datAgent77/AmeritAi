rules_version = '2';

// Storage rules for Vois AI.
// Reads are public because brand assets (logos, uploaded images) are displayed
// on customers' own websites to anonymous visitors. Writes require authentication
// and are size-capped. Tighten writes to per-tenant folders once paths are fixed.
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024; // 10 MB cap
    }
  }
}
