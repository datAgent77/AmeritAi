# ============================================
# Vion AI — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values

# Application
# Production example:
# NEXT_PUBLIC_APP_URL=https://www.ameritai.com
# If you intentionally use the root domain as canonical instead of www:
# NEXT_PUBLIC_APP_URL=https://ameritai.com
# Local development example:
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_GA_ID=G-97SQS8BW2W

# Firebase Client (Public)
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase Admin (Server — KEEP SECRET)
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"

# AI Services (Server — KEEP SECRET)
OPENAI_API_KEY=sk-proj-your-openai-key
PINECONE_API_KEY=your-pinecone-key
GEMINI_API_KEY=your-gemini-key
# Anthropic (Claude) — selectable AI provider. Get a key at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_AGENT_ID=your-elevenlabs-conversational-ai-agent-id
ELEVENLABS_CONVAI_ENVIRONMENT=production

# Optional: Secure cron endpoints
CRON_SECRET=your-random-long-secret

# Auth / Verification (Optional feature flags)
# Set AUTH_CUSTOM_VERIFICATION_EMAILS_ENABLED=true in production if you want verification
# emails to come from your own SMTP provider instead of Firebase's default template.
NEXT_PUBLIC_AUTH_EMAIL_VERIFICATION_BYPASS_NEW_SIGNUPS=false
AUTH_EMAIL_VERIFICATION_BYPASS_NEW_SIGNUPS=false
AUTH_CUSTOM_VERIFICATION_EMAILS_ENABLED=false

# SMTP configuration for transactional emails (contact + verification)
# Recommended for production: verify ameritai.com or a sending subdomain
# (for example mail.ameritai.com) in a transactional email provider and add
# its SPF, DKIM, and DMARC DNS records. A mailbox/mail server is not required
# for outbound transactional emails.
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=resend
SMTP_PASS=your-transactional-email-api-key
SMTP_FROM_EMAIL=no-reply@ameritai.com
SMTP_FROM_NAME=Vion AI
VION_ADMIN_EMAIL=info@ameritai.com
VION_CONTACT_EMAIL=info@ameritai.com

# Optional: Verify WhatsApp webhook signatures (Meta app secret)
WHATSAPP_APP_SECRET=your-meta-app-secret

# Facebook Messenger integration
PAGE_ACCESS_TOKEN=your-facebook-page-access-token
VERIFY_TOKEN=your-facebook-webhook-verify-token
MESSENGER_API_VERSION=v19.0
PORT=3001
LOG_LEVEL=info

# Meta webhook verification token
# Use the exact same value in the Meta Developer dashboard webhook setup.
META_WEBHOOK_VERIFY_TOKEN=change-this-meta-webhook-token

# Optional: Distributed rate limiting (recommended for multi-instance deployments)
# Create a free Redis database on Upstash and set these values to enable shared limits.
UPSTASH_REDIS_REST_URL=https://your-upstash-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# Optional: extra origins allowed to make credentialed cross-origin calls to
# privileged admin/console/agency APIs (comma-separated). ameritai.com domains and
# localhost are always allowed. Add new brand/admin domains here.
# Example: ADMIN_ALLOWED_ORIGINS=https://admin.newbrand.com,https://app.newbrand.com
ADMIN_ALLOWED_ORIGINS=

# Comma-separated emails granted SUPER_ADMIN in the UI (client-side convenience).
# The authoritative role is the Firestore users/{uid}.role field (honored server-side).
# Example: NEXT_PUBLIC_SUPER_ADMIN_EMAILS=you@yourbrand.com
NEXT_PUBLIC_SUPER_ADMIN_EMAILS=

# --- Billing (Stripe) -------------------------------------------------------
# Secret key from the Stripe dashboard (use the test key sk_test_... first).
STRIPE_SECRET_KEY=
# Price IDs for each plan (create Products+Prices in Stripe, paste price_... ids).
# Keys match app plan ids: starter | growth | enterprise (see lib/pricing-config).
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_ENTERPRISE=
# Optional publishable key if you later add client-side Stripe.js
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret (whsec_...) — needed for the NEXT milestone (access sync).
STRIPE_WEBHOOK_SECRET=

# Optional: forward server errors to a webhook (Slack/Sentry relay/logger).
# Leave empty to only log to the host console. Wire Sentry here later.
ERROR_WEBHOOK_URL=
