# ============================================
# Vion AI — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Firebase Client (Public)
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase Admin (Server — KEEP SECRET)
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"

# AI Services (Server — KEEP SECRET)
OPENAI_API_KEY=sk-proj-your-openai-key
PINECONE_API_KEY=your-pinecone-key
GEMINI_API_KEY=your-gemini-key

# Optional: Secure cron endpoints
CRON_SECRET=your-random-long-secret

# Auth / Verification (Optional feature flags)
NEXT_PUBLIC_AUTH_EMAIL_VERIFICATION_BYPASS_NEW_SIGNUPS=false
AUTH_EMAIL_VERIFICATION_BYPASS_NEW_SIGNUPS=false
AUTH_CUSTOM_VERIFICATION_EMAILS_ENABLED=false

# SMTP Configuration for Contact Form
# Gmail: Use your email and an 'App Password' (not your login password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here
SMTP_FROM_EMAIL=no-reply@yourdomain.com
SMTP_FROM_NAME=Vion AI

# Optional: Verify WhatsApp webhook signatures (Meta app secret)
WHATSAPP_APP_SECRET=your-meta-app-secret

# Optional: Distributed rate limiting (recommended for multi-instance deployments)
# Create a free Redis database on Upstash and set these values to enable shared limits.
UPSTASH_REDIS_REST_URL=https://your-upstash-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
