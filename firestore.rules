rules_version = '2';

// ---------------------------------------------------------------------------
// Firestore security rules for Vois AI
//
// Model: the backend uses the Firebase ADMIN SDK for all privileged work, which
// BYPASSES these rules entirely. These rules therefore only govern DIRECT CLIENT
// access (dashboard + widget). Principle: deny by default; allow a tenant to read
// and write ONLY their own data; allow SUPER_ADMIN / AGENCY_ADMIN broader read.
//
// IMPORTANT: Test in the Firebase Console "Rules Playground" and against the
// running app before deploying to production. Tighten further once verified.
// Deploy with:  firebase deploy --only firestore:rules
// ---------------------------------------------------------------------------

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers ----------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }
    function uid() {
      return request.auth.uid;
    }
    // The caller's own user document (used for role checks).
    function selfData() {
      return get(/databases/$(database)/documents/users/$(uid())).data;
    }
    function selfRole() {
      return isSignedIn() ? selfData().role : null;
    }
    function isSuperAdmin() {
      return isSignedIn() && selfRole() == 'SUPER_ADMIN';
    }
    function isAgencyAdmin() {
      return isSignedIn() && selfRole() == 'AGENCY_ADMIN';
    }
    function isStaff() {
      return isSuperAdmin() || isAgencyAdmin();
    }

    // Ownership: a doc belongs to the caller if it is keyed by / carries their uid.
    function ownsExisting() {
      return isSignedIn() && (
        (('chatbotId' in resource.data) && resource.data.chatbotId == uid()) ||
        (('userId' in resource.data) && resource.data.userId == uid()) ||
        (('ownerId' in resource.data) && resource.data.ownerId == uid()) ||
        (('uid' in resource.data) && resource.data.uid == uid())
      );
    }
    function ownsIncoming() {
      return isSignedIn() && (
        (('chatbotId' in request.resource.data) && request.resource.data.chatbotId == uid()) ||
        (('userId' in request.resource.data) && request.resource.data.userId == uid()) ||
        (('ownerId' in request.resource.data) && request.resource.data.ownerId == uid()) ||
        (('uid' in request.resource.data) && request.resource.data.uid == uid())
      );
    }

    // ---- Users ------------------------------------------------------------
    // Own profile readable; staff can read any. Users may update their own
    // profile but CANNOT self-escalate privileged fields (role/plan/etc.).
    match /users/{userId} {
      allow read: if isSignedIn() && (uid() == userId || isStaff());
      allow create: if isSignedIn() && uid() == userId;
      allow update: if isSuperAdmin() || (
        uid() == userId &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'role', 'planId', 'plan', 'subscriptionStatus', 'trialEndsAt',
          'entitlements', 'emailVerificationBypass', 'isActive',
          'agencyId', 'agentTenantId', 'partnerLevel', 'stripeCustomerId',
          'stripeSubscriptionId'
        ])
      );
      allow delete: if isSuperAdmin();
    }

    // ---- Chatbots (keyed by owner uid) ------------------------------------
    match /chatbots/{chatbotId} {
      allow read: if isSignedIn() && (uid() == chatbotId || isStaff());
      allow write: if isSignedIn() && (uid() == chatbotId || isSuperAdmin());
    }

    // ---- Tenant-owned collections (carry chatbotId / userId / ownerId) ----
    // Explicitly listed; everything else falls through to deny-by-default.
    match /knowledge_docs/{docId}        { allow read, write: if ownsExisting() || ownsIncoming() || isStaff(); }
    match /leads/{docId}                 { allow read, write: if ownsExisting() || ownsIncoming() || isStaff(); }
    match /appointments/{docId}          { allow read, write: if ownsExisting() || ownsIncoming() || isStaff(); }
    match /products/{docId}              { allow read, write: if ownsExisting() || ownsIncoming() || isStaff(); }
    match /digital_waiter_menu/{docId}   { allow read, write: if ownsExisting() || ownsIncoming() || isStaff(); }
    match /waiter_requests/{docId}       { allow read, write: if ownsExisting() || ownsIncoming() || isStaff(); }
    match /brand_info/{docId}            { allow read, write: if ownsExisting() || ownsIncoming() || isStaff(); }
    match /upgrade_requests/{docId}      { allow read, write: if ownsExisting() || ownsIncoming() || isStaff(); }

    // Notifications are usually per-user.
    match /notifications/{docId}         { allow read, write: if ownsExisting() || ownsIncoming() || isStaff(); }

    // Chat sessions (and any nested messages) scoped by chatbotId.
    match /chat_sessions/{sessionId} {
      allow read, write: if ownsExisting() || ownsIncoming() || isStaff();
      match /{sub=**} {
        allow read, write: if isStaff() ||
          (isSignedIn() &&
            get(/databases/$(database)/documents/chat_sessions/$(sessionId)).data.chatbotId == uid());
      }
    }

    // ---- Default deny -----------------------------------------------------
    // Any collection not matched above is inaccessible from the client.
    // (Server-side Admin SDK access is unaffected by these rules.)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
